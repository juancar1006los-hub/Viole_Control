# ESP32-CAM tetap menyediakan stream MJPEG langsung ke browser.
CAMERA_STREAM_URL=http://192.168.1.51:81/stream

# Broker Mosquitto/EMQX yang bisa dijangkau backend dan ESP32 utama.
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CONTROL_TOPIC=robot/control
MQTT_TELEMETRY_TOPIC=robot/telemetry
